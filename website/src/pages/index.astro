---
import { Image } from 'astro:assets';
import LandingLayout from '../layouts/LandingLayout.astro';
import logo from '../assets/logo.png';

const GH = 'https://github.com/mwouts/jupytext';

const benefits = [
	{
		icon: '­¤öŹ',
		title: 'Clean, reviewable diffs',
		body: 'No more unreadable JSON blobs. Text notebooks produce line-by-line diffs you can actually review in a pull request.',
	},
	{
		icon: 'Ō£Å’ĖÅ',
		title: 'Edit in any IDE',
		body: 'Open your notebooks in VS Code, PyCharm, Spyder, vim ŌĆö anywhere. No JSON, no merge nightmares, full editor superpowers.',
	},
	{
		icon: '­¤¦╣',
		title: 'Refactor, lint & format',
		body: 'Run black, ruff, isort or flake8 over your notebooks like ordinary scripts. Pipe them through any tool from the CLI.',
	},
	{
		icon: 'ŌÖ╗’ĖÅ',
		title: 'Reuse your code',
		body: 'A text notebook is a valid module. Import functions from it, or run it as a script. Copy, move, and restructure your code at will.',
	},
	{
		icon: '­¤öŚ',
		title: 'Rich outputs are preserved',
		body: 'Pair the text file with an .ipynb and keep your rich outputs. Inputs come from the text, outputs from the notebook.',
	},
	{
		icon: '­¤īÉ',
		title: 'Many languages & formats',
		body: 'Python, R, Julia and more ŌĆö as percent scripts, Markdown, MyST, Quarto or Pandoc. Pick what fits each notebook.',
	},
];

const formats = [
	{
		id: 'percent',
		label: 'py:percent',
		filename: 'notebook.py',
		featured: true,
		best: 'Explicit # %% cell markers ŌĆö understood by VS Code, PyCharm, Spyder, supported in 30+ languages.',
		code: `# %% [markdown]
# # Quarterly Sales
# A look at Q4 revenue by region.

# %%
import pandas as pd
df = pd.read_csv("sales.csv")

# %%
df.groupby("region")["revenue"].sum().plot.bar()`,
	},
	{
		id: 'light',
		label: 'py:light',
		filename: 'notebook.py',
		best: 'Minimal markers ŌĆö barely looks different from a regular script. Use py:nomarker to drop them entirely.',
		code: `# # Quarterly Sales
# A look at Q4 revenue by region.

import pandas as pd
df = pd.read_csv("sales.csv")

# %%
df.groupby("region")["revenue"].sum().plot.bar()`,
	},
	{
		id: 'marimo',
		label: 'py:marimo',
		filename: 'notebook.py',
		best: 'Each cell becomes a reactive function ŌĆö open the file directly in Marimo.',
		code: `import marimo

app = marimo.App()


@app.cell(hide_code=True)
def _(mo):
    mo.md(r"""
    # Quarterly Sales
    A look at Q4 revenue by region.
    """)
    return


@app.cell
def _():
    import pandas as pd
    df = pd.read_csv("sales.csv")
    return df, pd


@app.cell
def _(df):
    df.groupby("region")["revenue"].sum().plot.bar()
    return


if __name__ == "__main__":
    app.run()`,
	},
	{
		id: 'md',
		label: 'Markdown',
		filename: 'notebook.md',
		best: 'Plain GitHub Markdown ŌĆö prose-first, readable everywhere.',
		code: `# Quarterly Sales

A look at Q4 revenue by region.

\`\`\`python
import pandas as pd
df = pd.read_csv("sales.csv")
\`\`\`

\`\`\`python
df.groupby("region")["revenue"].sum().plot.bar()
\`\`\``,
	},
	{
		id: 'myst',
		label: 'MyST Markdown',
		filename: 'notebook.myst.md',
		featured: true,
		best: 'Rich directives and cross-references for Jupyter Book and technical publishing.',
		code: `# Quarterly Sales

A look at Q4 revenue by region.

\`\`\`{code-cell} ipython3
import pandas as pd
df = pd.read_csv("sales.csv")
\`\`\`

\`\`\`{code-cell} ipython3
df.groupby("region")["revenue"].sum().plot.bar()
\`\`\``,
	},
	{
		id: 'quarto',
		label: 'Quarto',
		filename: 'notebook.qmd',
		best: 'Multi-language scientific publishing ŌĆö Python, R, Julia and more via the Quarto system.',
		code: `# Quarterly Sales

A look at Q4 revenue by region.

\`\`\`{python}
import pandas as pd
df = pd.read_csv("sales.csv")
\`\`\`

\`\`\`{python}
df.groupby("region")["revenue"].sum().plot.bar()
\`\`\``,
	},
];


const k = (s: string) => `<span class="key">${s}</span>`;
const v = (s: string) => `<span class="str">${s}</span>`;
const ipynbHtml = [
	'{',
	` ${k('"cells"')}: [`,
	'  {',
	`   ${k('"cell_type"')}: ${v('"markdown"')},`,
	`   ${k('"source"')}: [${v('"# Quarterly Sales\\n"')}, ${v('"\\n"')}, ${v('"A look at Q4 revenue by region."')}]`,
	'  },',
	'  {',
	`   ${k('"cell_type"')}: ${v('"code"')},`,
	`   ${k('"execution_count"')}: 1,`,
	`   ${k('"outputs"')}: [],`,
	`   ${k('"source"')}: [${v('"import pandas as pd\\n"')}, ${v('"df = pd.read_csv(\\"sales.csv\\")"')}]`,
	'  },',
	'  {',
	`   ${k('"cell_type"')}: ${v('"code"')},`,
	`   ${k('"execution_count"')}: 2,`,
	`   ${k('"outputs"')}: [{${k('"data"')}: {${k('"image/png"')}: ${v('"iVBORw0KGgo..."')}}, ${k('"output_type"')}: ${v('"display_data"')}}],`,
	`   ${k('"source"')}: [${v('"df.groupby(\\"region\\")[\\"revenue\\"].sum().plot.bar()"')}]`,
	'  }',
	' ],',
	` ${k('"metadata"')}: {${k('"kernelspec"')}: {${k('"display_name"')}: ${v('"Python 3"')}, ${k('"language"')}: ${v('"python"')}, ${k('"name"')}: ${v('"python3"')}}},`,
	` ${k('"nbformat"')}: 4,`,
	` ${k('"nbformat_minor"')}: 5`,
	'}',
].join('\n');

const integrations = [
	{ name: 'JupyterLab', desc: 'Pair & open text notebooks with a right click.', href: '/getting-started/text-notebooks/#how-to-open-a-text-notebook-in-jupyterlab' },
	{ name: 'Jupyter Notebook', desc: 'Works in Notebook 7 and classic.', href: '/getting-started/text-notebooks/#how-to-open-a-text-notebook-in-jupyter-notebook-nb7' },
	{ name: 'VS Code Extension', desc: 'Jupytext-Sync by Victor Neg├«rneac.', href: '/integrations/vs-code/' },
	{ name: 'Real-time collab', desc: 'Jupyter Collaboration support.', href: '/integrations/jupyter-collaboration/' },
	{ name: 'pre-commit', desc: 'Keep pairs in sync on every commit.', href: '/using/pre-commit/' },
	{ name: 'Python API', desc: 'read / write notebooks in code.', href: '/getting-started/install/#jupytext-as-a-python-library' },
];
---

<LandingLayout>
	<!-- Nav -->
	<header class="lp-nav">
		<div class="lp-container">
			<a href="/" aria-label="Jupytext home"><Image src={logo} alt="Jupytext" width={140} densities={[1.5, 2]} /></a>
			<nav class="lp-nav-links">
				<a class="nav-hide-sm" href="/getting-started/introduction/">Docs</a>
				<a class="nav-hide-sm" href="/getting-started/install/">Get started</a>
				<a href={GH} target="_blank" rel="noopener">GitHub<span id="gh-stars" class="gh-stars"></span></a>
			</nav>
		</div>
	</header>

	<!-- Hero -->
	<section>
		<div class="lp-container">
			<div class="section-head">
				<div class="lp-hero-eyebrow">Jupyter ecosystem ┬Ę open source</div>
				<h1>Your notebooks,<br>as plain <span class="grad">text.</span></h1>
				<p class="lede">
					Jupytext saves Jupyter notebooks as <code>.py</code> or <code>.md</code> files ŌĆö easy to edit
					in any IDE, friendly to version control, and trivial for AI assistants to read and refactor.
				</p>
			</div>
		</div>
		<div class="lp-container" style="margin-top: 2.5rem">
			<div class="lp-demo-card" data-tabs>
				<!-- Horizontal grouped tab bar -->
				<div class="lp-demo-tabbar">
					<div class="lp-demo-group-cluster">
						<span class="lp-demo-group-lbl">Jupyter formats</span>
						<div class="lp-demo-group-tabs">
							<button class="lp-demo-tab" role="tab" aria-selected="false">Ō¢Č Notebook</button>
							<button class="lp-demo-tab" role="tab" aria-selected="false">notebook.ipynb<span class="lp-demo-dot" aria-hidden="true"></span></button>
						</div>
					</div>
					<div class="lp-demo-group-cluster">
						<span class="lp-demo-group-lbl">Script formats</span>
						<div class="lp-demo-group-tabs">
							{formats.slice(0, 3).map((f) => (
								<button class:list={['lp-demo-tab', f.featured && 'lp-demo-tab--featured']} role="tab" aria-selected={f.id === 'percent' ? 'true' : 'false'}>
									{f.label}{f.featured && <span class="lp-demo-dot" aria-hidden="true"></span>}
								</button>
							))}
						</div>
					</div>
					<div class="lp-demo-group-cluster">
						<span class="lp-demo-group-lbl">Markdown formats</span>
						<div class="lp-demo-group-tabs">
							{formats.slice(3).map((f) => (
								<button class:list={['lp-demo-tab', f.featured && 'lp-demo-tab--featured']} role="tab" aria-selected="false">
									{f.label}{f.featured && <span class="lp-demo-dot" aria-hidden="true"></span>}
								</button>
							))}
						</div>
					</div>
				</div>

				<!-- Panels -->
				<div class="lp-demo-panels">
					<!-- Panel 1: rendered notebook -->
					<div role="tabpanel" hidden class="lp-nb-render">
						<div class="lp-nb-md">
							<h2>Quarterly Sales</h2>
							<p>A look at Q4 revenue by region.</p>
						</div>
						<div class="lp-nb-cell">
							<span class="lp-nb-prompt">[1]:</span>
							<pre class="lp-nb-code">import pandas as pd
df = pd.read_csv("sales.csv")</pre>
						</div>
						<div class="lp-nb-cell">
							<span class="lp-nb-prompt">[2]:</span>
							<div class="lp-nb-output">
								<pre class="lp-nb-code">df.groupby("region")["revenue"].sum().plot.bar()</pre>
								<div class="lp-nb-chart">
									<div class="lp-nb-bars">
										<div class="lp-nb-bar" style="height:62px"></div>
										<div class="lp-nb-bar" style="height:85px"></div>
										<div class="lp-nb-bar" style="height:44px"></div>
										<div class="lp-nb-bar" style="height:73px"></div>
									</div>
									<div class="lp-nb-labels">
										<span class="lp-nb-label">North</span>
										<span class="lp-nb-label">South</span>
										<span class="lp-nb-label">East</span>
										<span class="lp-nb-label">West</span>
									</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Panel 2: notebook.ipynb JSON -->
					<div role="tabpanel" hidden>
						<pre class="lp-demo-pre" set:html={ipynbHtml}></pre>
						<p class="lp-demo-note">JSON format ┬Ę requires Jupyter or VS Code ┬Ę not well suited to manual edits or version control</p>
					</div>

					<!-- Panels: text formats -->
					{formats.map((f) => (
						<div role="tabpanel" hidden={f.id !== 'percent'}>
							<pre class="lp-demo-pre">{f.code}</pre>
							{f.best && <p class="lp-demo-note">{f.best}</p>}
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<!-- What Jupytext enables -->
	<section>
		<div class="lp-container">
			<div class="section-head">
				<span class="eyebrow">What Jupytext enables</span>
				<h2>Change one thing ŌĆö the file format ŌĆö and everything else gets easier.</h2>
			</div>
			<div class="lp-grid">
				<article class="lp-feature">
					<div class="ico">┬▒</div>
					<h3>Clean git diffs</h3>
					<p>See what changed in your code ŌĆö not a wall of JSON, metadata and base64 outputs.</p>
				</article>
				<article class="lp-feature">
					<div class="ico">&lt;/&gt;</div>
					<h3>Edit anywhere</h3>
					<p>Open notebooks in VS Code, PyCharm, Vim ŌĆö any editor, with full language tooling.</p>
				</article>
				<article class="lp-feature">
					<div class="ico">Ō£ō</div>
					<h3>Lint &amp; refactor</h3>
					<p>Run black, isort, flake8 and pre-commit hooks across your notebooks like normal code.</p>
				</article>
				<article class="lp-feature">
					<div class="ico">Ōćä</div>
					<h3>Two-way sync</h3>
					<p>Pair an .ipynb with a .py or .md ŌĆö edits in either stay in sync automatically.</p>
				</article>
				<article class="lp-feature">
					<div class="ico">PR</div>
					<h3>Review like code</h3>
					<p>Notebooks become readable diffs your team can actually review in a pull request.</p>
				</article>
				<article class="lp-feature">
					<div class="ico">Ō£”</div>
					<h3>Ready for AI</h3>
					<p>Coding agents read and edit the clean text form ŌĆö so AI can refactor, explain and extend your notebooks.</p>
				</article>
			</div>
		</div>

		<div class="lp-container" style="margin-top: 2rem">
			<div class="lp-works-strip">
				<span class="lp-works-label">works with</span>
				<a href="/getting-started/install/#jupytext-commands-in-jupyterlab">JupyterLab</a>
				<span class="lp-works-dot">┬Ę</span>
				<a href="/getting-started/install/#jupytext-menu-in-jupyter-notebook">Jupyter Notebook</a>
				<span class="lp-works-dot">┬Ę</span>
				<a href="/formats/markdown/#myst-markdown">Jupyter Book</a>
				<span class="lp-works-dot">┬Ę</span>
				<a href="/integrations/vs-code/">VS Code</a>
				<span class="lp-works-dot">┬Ę</span>
				<a href="/formats/markdown/#quarto">Quarto</a>
				<span class="lp-works-dot">┬Ę</span>
				<a href="/using/pre-commit/">pre-commit</a>
			</div>
		</div>
	</section>

	<!-- AI band -->
	<section class="lp-ai">
		<div class="lp-container">
			<div>
				<span class="eyebrow">New superpower</span>
				<h2>Notebooks your AI assistant can actually read</h2>
				<p>
					Coding assistants like Claude, GitHub Copilot and Cursor work in plain text. Pair your
					notebooks with Jupytext and they can read, edit and refactor them directly ŌĆö no JSON
					wrangling, no broken outputs, no special tooling.
				</p>
				<ul>
					<li><span class="tick">Ō£ō</span> Ask an agent to refactor a cell ŌĆö it edits the .py file, you reload in Jupyter.</li>
					<li><span class="tick">Ō£ō</span> Reviews and AI suggestions land as clean, minimal diffs.</li>
					<li><span class="tick">Ō£ō</span> Outputs stay safe in the paired .ipynb while the text gets edited.</li>
					<li><span class="tick">Ō£ō</span> Text notebooks are very concise, often 1,000x lighter than .ipynb, allowing your AI to ingest an entire collection of notebooks at once.</li>
				</ul>
			</div>
			<div class="lp-card">
				<div class="lp-card-bar">
					<span class="dot"></span><span class="dot"></span><span class="dot"></span>
					<span class="fname">assistant editing analysis.py</span>
				</div>
				<pre class="lp-code"><code><span class="cmt"># %% [markdown]</span>
<span class="cmt"># ### Refactor: vectorize the loop ­¤ż¢</span>

<span class="del">- totals = []</span>
<span class="del">- for r in regions:</span>
<span class="del">-     totals.append(df[df.region==r].sales.sum())</span>
<span class="add">+ totals = df.groupby("region").sales.sum()</span></code></pre>
			</div>
		</div>
	</section>


	<!-- Stats -->
	<section class="lp-stats">
		<div class="lp-container">
			<a class="lp-stat" href="https://github.com/mwouts/jupytext" target="_blank" rel="noopener noreferrer"><div class="num">7k+</div><div class="lab">GitHub stars</div></a>
			<a class="lp-stat" href="https://pypistats.org/packages/jupytext" target="_blank" rel="noopener noreferrer"><div class="num">3M+</div><div class="lab">Downloads / month</div></a>
			<a class="lp-stat" href="/formats/languages/"><div class="num">30+</div><div class="lab">Languages supported</div></a>
			<a class="lp-stat" href="https://github.com/mwouts/jupytext/graphs/contributors" target="_blank" rel="noopener noreferrer"><div class="num">100+</div><div class="lab">Contributors</div></a>
			<a class="lp-stat" href="https://github.com/mwouts/jupytext/blob/main/LICENSE" target="_blank" rel="noopener noreferrer"><div class="num">MIT</div><div class="lab">Open source</div></a>
		</div>
	</section>

	<!-- About -->
	<section style="border-top:1px solid var(--lp-border)">
		<div class="lp-container" style="max-width:44rem;text-align:center">
			<div class="section-head">
				<h2>Keeping in touch</h2>
			</div>
			<p style="color:var(--lp-text-dim);line-height:1.7">
				Jupytext was created by <a href="https://www.linkedin.com/in/marc-wouts" target="_blank" rel="noopener">Marc Wouts</a>.
				Follow Marc on LinkedIn for updates on Jupytext, his other open-source projects, and the occasional random topic.
			</p>
			<p style="color:var(--lp-text-dim);line-height:1.7">
				Jupytext is completely free and open source under the <strong>MIT license</strong>. What keeps us going is
				the excitement of learning through interactions with users and experts, and the satisfaction of sharing solutions with the community.
				<br /><br />
				Have a question, a bug report, or an idea? Join us on <a href="https://discord.gg/VfdAsYyn" target="_blank" rel="noopener">Discord</a>,
				or open an issue or start a discussion on <a href={GH} target="_blank" rel="noopener">GitHub</a>.
			</p>
		</div>
	</section>

	<!-- Footer -->
	<footer class="lp-footer">
		<div class="lp-container">
			<div>Jupytext ŌĆö Jupyter notebooks as plain text. MIT licensed.</div>
			<nav>
				<a href="/getting-started/introduction/">Docs</a>
				<a href="/getting-started/install/">Install</a>
				<a href="/reference/faq/">FAQ</a>
				<a href="/reference/contributing/">Contributing</a>
				<a href={GH} target="_blank" rel="noopener">GitHub</a>
			</nav>
		</div>
	</footer>
</LandingLayout>
