{
  "compilerOptions": {
    "declaration": true,
    "lib": ["es2018", "dom"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "noEmitOnError": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "rootDir": "src",
    "strict": true,
    "strictNullChecks": false,
    "target": "es2018",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/*"]
}
