/* %% [markdown] */
/* # Jenner Notebooks with Jupytext */

/* %% */
data test;
    x = 1;
    y = x * 2;
    output;
run;

/* %% */
proc print data=test;
run;

/* %% */
%let name = Jupytext;
%put &name;
